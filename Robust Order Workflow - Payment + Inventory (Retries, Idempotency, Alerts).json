      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst body = $input.first().json.body ?? $input.first().json;\n\nconst orderId = body.orderId;\nconst customerId = body.customerId;\nconst amount = body.amount;\n\nif (orderId === undefined || customerId === undefined || amount === undefined) {\n  throw new Error('Missing required fields: orderId, customerId, amount');\n}\n\n// Optional fields that let you control which saved Postman mock example\n// is returned, so you can demo each error path on demand.\n// paymentTestMode: 'normal' (429 -> 500 -> 200), 'always_success', 'always_fail'\n// inventoryTestMode: 'success', 'conflict'\nconst paymentTestMode = body.paymentTestMode || 'normal';\nconst inventoryTestMode = body.inventoryTestMode || 'success';\n\nconst raw = `${orderId}|${customerId}|${amount}`;\nconst idempotencyKey = crypto.createHash('sha256').update(raw).digest('hex');\n\nreturn [{\n  json: {\n    orderId,\n    customerId,\n    amount,\n    idempotencyKey,\n    paymentTestMode,\n    inventoryTestMode,\n    receivedAt: new Date().toISOString()\n  }\n}];"
      },
