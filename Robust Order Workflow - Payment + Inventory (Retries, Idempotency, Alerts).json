        "jsCode": "const attempt = $('Retry Loop').item.json.attempt;\nconst statusCode = $json.statusCode;\nconst order = $('Generate Idempotency Key1').item.json;\nconst errorType = ([429,500].includes(statusCode) && attempt >= 3) ? 'retry_exhausted' : 'non_retryable_status';\nreturn [{\n  json: {\n    idempotencyKey: order.idempotencyKey,\n    orderId: order.orderId,\n    errorType,\n    errorMessage: `Payment API failed with status ${statusCode} after ${attempt} attempt(s)`,\n    timestamp: new Date().toISOString()\n  }\n}];"
